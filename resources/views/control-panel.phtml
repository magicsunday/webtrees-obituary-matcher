<script>
    // Progressive enhancement for the additional-finders list (§5.2f increment 2): add and remove rows
    // client-side, and probe a single row via the hidden test form. The list works without this script —
    // the server-rendered rows are fully editable and saveable; only add/remove/per-row-test need it.
    (function () {
        "use strict";

        const container = document.getElementById("wt-obituary-additional-finders");

        if (container === null) {
            return;
        }

        const template = document.getElementById("wt-obituary-additional-finder-template");
        const addButton = document.getElementById("wt-obituary-add-finder");
        const testForm = document.getElementById("wt-obituary-additional-finder-test-form");
        const testBaseUrl = document.getElementById("wt-obituary-additional-test-base-url");
        const testToken = document.getElementById("wt-obituary-additional-test-token");
        const testRemove = document.getElementById("wt-obituary-additional-test-remove");

        // The next free row index, seeded from the count of server-rendered rows so a newly added row
        // never collides with an existing one.
        let nextIndex = Number(container.dataset.nextIndex);

        // The per-row test needs the hidden test form and its three fields; bind the test button only when
        // all are present, so a customized template that drops one cannot NPE on a `.value` write.
        const canTest = (testForm !== null)
            && (testBaseUrl !== null)
            && (testToken !== null)
            && (testRemove !== null);

        const bindRow = function (row) {
            const removeButton = row.querySelector("[data-remove-additional-finder]");

            if (removeButton !== null) {
                removeButton.addEventListener("click", function () {
                    row.remove();
                });
            }

            const testButton = row.querySelector("[data-test-additional-finder]");

            if ((testButton !== null) && canTest) {
                testButton.addEventListener("click", function () {
                    const baseUrlInput = row.querySelector("input[name$=\"[base_url]\"]");
                    const tokenInput = row.querySelector("input[name$=\"[token]\"]");
                    const removeInput = row.querySelector("input[name$=\"[remove_token]\"]");

                    testBaseUrl.value = baseUrlInput === null ? "" : baseUrlInput.value;
                    testToken.value = tokenInput === null ? "" : tokenInput.value;

                    // Forward the row's remove-token intent so remove-wins holds: probing a row whose
                    // "Remove token" box is ticked tests it unauthenticated, matching what a save persists.
                    testRemove.value = ((removeInput !== null) && removeInput.checked) ? "1" : "";
                    testForm.submit();
                });
            }
        };

        container.querySelectorAll("[data-additional-finder-row]").forEach(bindRow);

        if ((addButton !== null) && (template !== null)) {
            addButton.addEventListener("click", function () {
                const markup = template.innerHTML.replace(/__INDEX__/g, String(nextIndex));
                nextIndex += 1;

                const wrapper = document.createElement("div");
                wrapper.innerHTML = markup;

                const row = wrapper.firstElementChild;

                if (row === null) {
                    return;
                }

                container.appendChild(row);
                bindRow(row);
            });
        }
    })();
</script>
