 *
 * The admin control-panel view: the prefilled candidate settings, a per-tree finder-trigger form and
 * the number of open finder jobs. The admin layout wraps it. Every dynamic sink is e()-escaped once and
 * each probe-status key maps to a literal I18N::translate() label here (so xgettext can extract it).
 */

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use MagicSunday\ObituaryMatcher\Domain\ScoreWeights;
use MagicSunday\ObituaryMatcher\Ui\ControlPanelView;
use MagicSunday\ObituaryMatcher\Webtrees\ObituaryControlPanelHandler;

/** @var ControlPanelView $view */

$finder = $view->finder;

// Each probe-status key maps to a literal I18N::translate() label here (so xgettext can extract it).
// Only the unreachable/invalid keys carry the error styling below.
$statusLabels = [
    'reachable'   => I18N::translate('The finder is reachable.'),
    'unreachable' => I18N::translate('The finder could not be reached.'),
    'invalid'     => I18N::translate('The finder connection is invalid.'),
];
?>

<h1><?= e(I18N::translate('Death notices')) ?></h1>

<form method="post" action="<?= e(route(ObituaryControlPanelHandler::ROUTE_NAME)) ?>">
    <?= csrf_field() ?>
    <input type="hidden" name="action" value="save">

    <label for="min_age"><?= e(I18N::translate('Minimum age')) ?></label>
    <input type="number" id="min_age" name="min_age" value="<?= e((string) $view->minAge) ?>" min="0" max="120">

    <label for="limit"><?= e(I18N::translate('Candidates per run')) ?></label>
    <input type="number" id="limit" name="limit" value="<?= e((string) $view->limit) ?>" min="1" max="500">

    <button type="submit"><?= e(I18N::translate('Save')) ?></button>
</form>

<h2><?= e(I18N::translate('Scoring weights')) ?></h2>

<p><?= e(I18N::translate('The maximum points each signal may contribute to a match score. Higher values weight a signal more heavily.')) ?></p>

<form method="post" action="<?= e(route(ObituaryControlPanelHandler::ROUTE_NAME)) ?>">
    <?= csrf_field() ?>
    <input type="hidden" name="action" value="save-weights">

    <label for="score_max_name"><?= e(I18N::translate('Name weight')) ?></label>
    <input type="number" id="score_max_name" name="score_max_name" value="<?= e((string) $view->weights->maxName) ?>" min="<?= e((string) ScoreWeights::FIELDS['maxName']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['maxName']['max']) ?>">

    <label for="score_max_birth"><?= e(I18N::translate('Birth-date weight')) ?></label>
    <input type="number" id="score_max_birth" name="score_max_birth" value="<?= e((string) $view->weights->maxBirth) ?>" min="<?= e((string) ScoreWeights::FIELDS['maxBirth']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['maxBirth']['max']) ?>">

    <label for="score_max_place"><?= e(I18N::translate('Place weight')) ?></label>
    <input type="number" id="score_max_place" name="score_max_place" value="<?= e((string) $view->weights->maxPlace) ?>" min="<?= e((string) ScoreWeights::FIELDS['maxPlace']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['maxPlace']['max']) ?>">

    <label for="score_max_plausibility"><?= e(I18N::translate('Plausibility weight')) ?></label>
    <input type="number" id="score_max_plausibility" name="score_max_plausibility" value="<?= e((string) $view->weights->maxPlausibility) ?>" min="<?= e((string) ScoreWeights::FIELDS['maxPlausibility']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['maxPlausibility']['max']) ?>">

    <label for="score_max_penalty"><?= e(I18N::translate('Conflict-penalty cap')) ?></label>
    <input type="number" id="score_max_penalty" name="score_max_penalty" value="<?= e((string) $view->weights->maxPenalty) ?>" min="<?= e((string) ScoreWeights::FIELDS['maxPenalty']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['maxPenalty']['max']) ?>">

    <label for="score_ambiguity_gap"><?= e(I18N::translate('Ambiguity gap')) ?></label>
    <input type="number" id="score_ambiguity_gap" name="score_ambiguity_gap" value="<?= e((string) $view->weights->ambiguityGap) ?>" min="<?= e((string) ScoreWeights::FIELDS['ambiguityGap']['min']) ?>" max="<?= e((string) ScoreWeights::FIELDS['ambiguityGap']['max']) ?>">

    <button type="submit"><?= e(I18N::translate('Save')) ?></button>
</form>

<form method="post" action="<?= e(route(ObituaryControlPanelHandler::ROUTE_NAME)) ?>">
    <?= csrf_field() ?>
    <input type="hidden" name="action" value="reset-weights">
    <button type="submit"><?= e(I18N::translate('Restore defaults')) ?></button>
</form>

<h3><?= e(I18N::translate('Band thresholds')) ?></h3>

<p><?= e(I18N::translate('These bands are fixed and shown for reference only. They are not editable.')) ?></p>

<ul>
    <li><?= e(I18N::translate('Strong')) ?>: <?= e((string) $view->bandThresholds['strong']) ?></li>
    <li><?= e(I18N::translate('Probable')) ?>: <?= e((string) $view->bandThresholds['probable']) ?></li>
    <li><?= e(I18N::translate('Possible')) ?>: <?= e((string) $view->bandThresholds['possible']) ?></li>
    <li><?= e(I18N::translate('Weak')) ?>: <?= e((string) $view->bandThresholds['weak']) ?></li>
</ul>

<h2><?= e(I18N::translate('Finder connection')) ?></h2>

<form method="post" action="<?= e(route(ObituaryControlPanelHandler::ROUTE_NAME)) ?>">
    <?= csrf_field() ?>

    <fieldset>
        <legend><?= e(I18N::translate('Finder connection')) ?></legend>

        <label for="base_url"><?= e(I18N::translate('REST base URL')) ?></label>
        <input type="text" id="base_url" name="base_url" value="<?= e($finder->baseUrl) ?>">

        <label for="token"><?= e(I18N::translate('Access token')) ?></label>
        <input type="password" id="token" name="token" autocomplete="new-password">
        <p><?= $finder->tokenIsSet ? e(I18N::translate('A token is set.')) : e(I18N::translate('No token set.')) ?></p>

        <label>
            <input type="checkbox" name="remove_token" value="1">
            <?= e(I18N::translate('Remove token')) ?>
        </label>

        <button type="submit" name="action" value="test"><?= e(I18N::translate('Test connection')) ?></button>
        <button type="submit" name="action" value="save-finder"><?= e(I18N::translate('Save finder connection')) ?></button>
    </fieldset>
</form>

<?php if ($finder->probe !== null) : ?>
    <?php $probe = $finder->probe; ?>

    <h3><?= e(I18N::translate('Connection test result')) ?></h3>

    <?php $statusIsError = ($probe->statusKey === 'unreachable') || ($probe->statusKey === 'invalid'); ?>
    <p class="<?= $statusIsError ? 'alert alert-danger' : 'alert alert-info' ?>">
        <?= e($statusLabels[$probe->statusKey] ?? $probe->statusKey) ?>
        <?php if (($probe->statusKey === 'unreachable') && ($probe->httpStatus !== null)) : ?>
            <?= e(I18N::translate('HTTP status: %s', (string) $probe->httpStatus)) ?>
        <?php endif ?>
    </p>

    <?php if ($probe->finderId !== null) : ?>
        <p><?= e(I18N::translate('Finder ID')) ?>: <?= e($probe->finderId) ?></p>
    <?php endif ?>
    <?php if ($probe->finderVersion !== null) : ?>
        <p><?= e(I18N::translate('Finder version')) ?>: <?= e($probe->finderVersion) ?></p>
    <?php endif ?>

    <?php if ($probe->schemaVersions !== []) : ?>
        <p>
            <?= e(I18N::translate('Advertised schema versions')) ?>:
            <?= e(implode(', ', $probe->schemaVersions)) ?>
        </p>
    <?php endif ?>

    <?php if ($probe->portals !== []) : ?>
        <table class="table wt-facts-table">
            <thead>
                <tr>
                    <th><?= e(I18N::translate('Portal')) ?></th>
                    <th><?= e(I18N::translate('Name')) ?></th>
                    <th><?= e(I18N::translate('Country')) ?></th>
                    <th><?= e(I18N::translate('Regions')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($probe->portals as $portal) : ?>
                    <tr>
                        <td><?= e($portal['id']) ?></td>
                        <td><?= e($portal['name']) ?></td>
                        <td><?= e($portal['country']) ?></td>
                        <td><?= e(implode(', ', $portal['regions'])) ?></td>
                    </tr>
                <?php endforeach ?>
            </tbody>
        </table>
    <?php endif ?>

    <?php if ($probe->noticeFields !== []) : ?>
        <p>
            <?= e(I18N::translate('Notice fields')) ?>:
            <?= e(implode(', ', $probe->noticeFields)) ?>
        </p>
    <?php endif ?>

    <?php
    // array_filter keeps only the truthy (enabled) flags; array_keys then yields their names.
    $enabledFeatures = array_keys(array_filter($probe->features));
    ?>
    <?php if ($enabledFeatures !== []) : ?>
        <p><?= e(I18N::translate('Supported features')) ?>: <?= e(implode(', ', $enabledFeatures)) ?></p>
    <?php endif ?>
<?php endif ?>

<h2><?= e(I18N::translate('Search for death notices')) ?></h2>

<?php if ($view->trees === []) : ?>
    <p><?= e(I18N::translate('No trees are available.')) ?></p>
<?php else : ?>
    <?php foreach ($view->trees as $tree) : ?>
        <form method="post" action="<?= e(route(ObituaryControlPanelHandler::ROUTE_NAME)) ?>">
            <?= csrf_field() ?>
            <input type="hidden" name="action" value="trigger">
            <input type="hidden" name="tree" value="<?= e((string) $tree['id']) ?>">
            <span><?= e($tree['name']) ?></span>
            <button type="submit"><?= e(I18N::translate('Start search')) ?></button>
        </form>
    <?php endforeach ?>
<?php endif ?>

<h2><?= e(I18N::translate('Open finder jobs')) ?></h2>

<?php if ($view->openJobCount === 0) : ?>
    <p><?= e(I18N::translate('No finder jobs are currently open.')) ?></p>
<?php else : ?>
    <p>
        <?= e(I18N::plural(
            '%s finder job is awaiting results.',
            '%s finder jobs are awaiting results.',
            $view->openJobCount,
            I18N::number($view->openJobCount),
        )) ?>
    </p>
<?php endif ?>
