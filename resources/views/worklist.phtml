<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Tree;
use MagicSunday\ObituaryMatcher\Ui\CandidateFilterView;
use MagicSunday\ObituaryMatcher\Ui\WorklistView;
use MagicSunday\ObituaryMatcher\Webtrees\CandidateCriteria;
use MagicSunday\ObituaryMatcher\Webtrees\ObituaryWorklistHandler;

/** @var Tree $tree */
/** @var WorklistView $view */
/** @var CandidateFilterView $candidateFilter */
$bandLabels = [
    'strong'   => I18N::translate('Strong match'),
    'probable' => I18N::translate('Probable match'),
    'possible' => I18N::translate('Possible match'),
    'weak'     => I18N::translate('Weak match'),
    'none'     => I18N::translate('No match'),
];

$bandIcons = [
    'strong'   => '●',
    'probable' => '●',
    'possible' => '◐',
    'weak'     => '○',
    'none'     => '○',
];

$statusLabels = [
    'pending'   => I18N::translate('Pending'),
    'uncertain' => I18N::translate('Uncertain'),
    'confirmed' => I18N::translate('Confirmed'),
    'rejected'  => I18N::translate('Rejected'),
];

$statusFilters = [
    'all'       => I18N::translate('All'),
    'open'      => I18N::translate('Open'),
    'confirmed' => I18N::translate('Confirmed'),
    'rejected'  => I18N::translate('Rejected'),
    'uncertain' => I18N::translate('Uncertain'),
];

$flagFilters = [
    'all'       => I18N::translate('All'),
    'conflict'  => I18N::translate('Conflicts'),
    'ambiguous' => I18N::translate('Ambiguous'),
];

$sortOptions = [
    'score' => I18N::translate('Score'),
    'name'  => I18N::translate('Name'),
    'death' => I18N::translate('Date of death'),
];

// The shared base params every worklist nav/pagination link carries; each link spreads these and
// overrides exactly the one dimension it changes, so a link can never silently drop the others (the
// pre-#65 pagination links dropped flag/sort until they were added — this keeps a single source of truth).
$navParams = [
    'tree'   => $tree->name(),
    'status' => $view->statusFilter,
    'flag'   => $view->flagFilter,
    'sort'   => $view->sort,
];
?>
<div class="om-worklist">
    <h2><?php echo e(I18N::translate('Death notices')); ?></h2>

    <section class="om-candidate-filter">
        <h3><?php echo e(I18N::translate('Preview who would be searched')); ?></h3>
        <form method="get" class="d-flex flex-wrap align-items-center gap-2" action="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, ['tree' => $tree->name()])); ?>">
            <input type="hidden" name="cand_preview" value="1">
            <label class="me-3">
                <?php echo e(I18N::translate('Minimum age')); ?>
                <input type="number" class="form-control" name="cand_min_age" min="<?php echo e((string) CandidateCriteria::AGE_FLOOR); ?>" max="<?php echo e((string) CandidateCriteria::AGE_CEILING); ?>" value="<?php echo e((string) $candidateFilter->minAge); ?>">
            </label>
            <label class="me-3">
                <?php echo e(I18N::translate('Maximum age')); ?>
                <input type="number" class="form-control" name="cand_max_age" min="<?php echo e((string) CandidateCriteria::AGE_FLOOR); ?>" max="<?php echo e((string) CandidateCriteria::AGE_CEILING); ?>" value="<?php echo e($candidateFilter->maxAge !== null ? (string) $candidateFilter->maxAge : ''); ?>">
            </label>
            <label class="form-check-label me-3">
                <input type="checkbox" class="form-check-input" name="cand_unknown_birth" value="1"<?php echo $candidateFilter->includeUnknownBirth ? ' checked' : ''; ?>>
                <?php echo e(I18N::translate('Include people without a known birth date')); ?>
            </label>
            <button type="submit" class="btn btn-primary"><?php echo e(I18N::translate('Preview count')); ?></button>
        </form>
        <?php if ($candidateFilter->matchCount !== null) { ?>
            <p class="om-candidate-count">≈ <?php echo e(I18N::plural('%s person would be searched', '%s people would be searched', $candidateFilter->matchCount, I18N::number($candidateFilter->matchCount) . ($candidateFilter->matchCountReachedCap ? '+' : ''))); ?></p>
        <?php } ?>
    </section>

    <?php if ($view->retryNeeded !== []) { ?>
        <section class="om-retry-needed">
            <h3><?php echo e(I18N::translate('Repeat search needed')); ?></h3>
            <p class="om-retry-needed-intro">
                <?php echo e(I18N::plural(
                    '%s person was searched but a portal was unavailable, so the result is incomplete — a repeat search is recommended.',
                    '%s people were searched but a portal was unavailable, so their results are incomplete — a repeat search is recommended.',
                    $view->retryNeededTotal,
                    I18N::number($view->retryNeededTotal),
                )); ?>
            </p>
            <ul class="om-retry-needed-list">
                <?php foreach ($view->retryNeeded as $person) { ?>
                    <li><a href="<?php echo e($person->personUrl); ?>"><?php echo e($person->personName); ?></a></li>
                <?php } ?>
            </ul>
            <?php if ($view->retryNeededTotal > count($view->retryNeeded)) { ?>
                <p class="om-retry-needed-more">
                    <?php echo e(I18N::translate('and %s more', I18N::number($view->retryNeededTotal - count($view->retryNeeded)))); ?>
                </p>
            <?php } ?>
        </section>
    <?php } ?>

    <p class="om-worklist-counts">
        <?php echo e(I18N::translate('Total: %d', $view->counts['total'])); ?>
    </p>

    <?php if ($view->counts['total'] === 0) { ?>
        <p class="om-worklist-empty"><?php echo e(I18N::translate('No obituary matches in this tree yet.')); ?></p>
    <?php } else { ?>
        <p class="om-worklist-breakdown">
            <?php echo e(I18N::translate(
                '%1$s open · %2$s confirmed · %3$s rejected · %4$s uncertain',
                I18N::number($view->counts['open']),
                I18N::number($view->counts['confirmed']),
                I18N::number($view->counts['rejected']),
                I18N::number($view->counts['uncertain']),
            )); ?>
        </p>

        <ul class="om-worklist-filters nav nav-pills">
            <?php foreach ($statusFilters as $key => $label) { ?>
                <li class="nav-item">
                    <a class="nav-link<?php echo $view->statusFilter === $key ? ' active' : ''; ?>"
                       href="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, [...$navParams, 'status' => $key])); ?>"><?php echo e($label); ?></a>
                </li>
            <?php } ?>
        </ul>

        <ul class="om-worklist-flags nav nav-pills">
            <?php foreach ($flagFilters as $key => $label) { ?>
                <li class="nav-item">
                    <a class="nav-link<?php echo $view->flagFilter === $key ? ' active' : ''; ?>"
                       href="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, [...$navParams, 'flag' => $key])); ?>"><?php echo e($label); ?></a>
                </li>
            <?php } ?>
        </ul>

        <p class="om-worklist-sort">
            <?php echo e(I18N::translate('Sort by')); ?>:
            <?php foreach ($sortOptions as $key => $label) { ?>
                <a class="om-sort-link<?php echo $view->sort === $key ? ' active' : ''; ?>"
                   href="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, [...$navParams, 'sort' => $key])); ?>"><?php echo e($label); ?></a>
            <?php } ?>
        </p>

        <?php if ($view->rows === []) { ?>
            <p class="om-worklist-empty"><?php echo e(I18N::translate('No matches for this filter.')); ?></p>
        <?php } else { ?>
            <?php
            // The bulk-reject form lives OUTSIDE the table so the per-row revert forms are not nested
            // inside it (invalid HTML); each rejectable row's checkbox associates with it via the HTML5
            // `form` attribute.
            ?>
            <form method="post" id="om-bulk-reject" class="om-bulk-reject-form" action="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, ['tree' => $tree->name()])); ?>">
                <?php echo csrf_field(); ?>
                <input type="hidden" name="action" value="bulk-reject">
                <button type="submit" class="btn btn-outline-danger btn-sm"><?php echo e(I18N::translate('Reject selected')); ?></button>
            </form>

            <table class="table table-sm om-worklist-table">
                <thead>
                    <tr>
                        <th><span class="visually-hidden"><?php echo e(I18N::translate('Select')); ?></span></th>
                        <th><?php echo e(I18N::translate('Individual')); ?></th>
                        <th><?php echo e(I18N::translate('Match')); ?></th>
                        <th><?php echo e(I18N::translate('Score')); ?></th>
                        <th><?php echo e(I18N::translate('Date of death')); ?></th>
                        <th><?php echo e(I18N::translate('Source')); ?></th>
                        <?php if ($view->hasMultipleOrigins) { ?>
                            <th><?php echo e(I18N::translate('Origin finder')); ?></th>
                        <?php } ?>
                        <th><?php echo e(I18N::translate('Status')); ?></th>
                        <th><span class="visually-hidden"><?php echo e(I18N::translate('Review')); ?></span></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($view->rows as $row) { ?>
                        <tr class="om-worklist-row om-band-<?php echo e($row->bandKey); ?>" data-xref="<?php echo e($row->personId); ?>">
                            <td class="om-select">
                                <?php if ($row->bulkRejectToken !== null) { ?>
                                    <input type="checkbox" class="form-check-input" form="om-bulk-reject" name="selected[]" value="<?php echo e($row->bulkRejectToken); ?>"
                                           aria-label="<?php echo e(I18N::translate('Select %s for bulk reject', $row->personName)); ?>">
                                <?php } ?>
                            </td>
                            <td>
                                <a href="<?php echo e($row->personUrl); ?>"><?php echo e($row->personName); ?></a>
                            </td>
                            <td class="om-band">
                                <span aria-hidden="true"><?php echo e($bandIcons[$row->bandKey] ?? '○'); ?></span>
                                <?php echo e($bandLabels[$row->bandKey] ?? $row->bandKey); ?>
                            </td>
                            <td class="om-score"><?php echo e((string) $row->score); ?></td>
                            <td class="om-death"><?php echo e($row->deathDate ?? ''); ?></td>
                            <td class="om-source">
                                <?php if ($row->sourceUrl !== null) { ?>
                                    <a href="<?php echo e($row->sourceUrl); ?>" target="_blank" rel="noopener noreferrer"><?php echo e($row->sourceHost ?? ''); ?></a>
                                <?php } else { ?>
                                    <?php echo e($row->sourceHost ?? ''); ?>
                                <?php } ?>
                            </td>
                            <?php if ($view->hasMultipleOrigins) { ?>
                                <td class="om-origin text-break"><?php echo e($row->originFinderId ?? ''); ?></td>
                            <?php } ?>
                            <td class="om-status"><?php echo e($statusLabels[$row->statusKey] ?? $row->statusKey); ?></td>
                            <td class="om-review">
                                <?php if ($row->reviewUrl !== null) { ?>
                                    <a class="btn btn-primary btn-sm" href="<?php echo e($row->reviewUrl); ?>"><?php echo e(I18N::translate('Review')); ?></a>
                                <?php } elseif ($row->revertObituaryUrl !== null) { ?>
                                    <form method="post" action="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, ['tree' => $tree->name()])); ?>">
                                        <?php echo csrf_field(); ?>
                                        <input type="hidden" name="action" value="revert">
                                        <input type="hidden" name="person" value="<?php echo e($row->personId); ?>">
                                        <input type="hidden" name="url" value="<?php echo e($row->revertObituaryUrl); ?>">
                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                                aria-label="<?php echo e(I18N::translate('Revert match for %s', $row->personName)); ?>"><?php echo e(I18N::translate('Revert')); ?></button>
                                    </form>
                                <?php } ?>
                            </td>
                        </tr>
                    <?php } ?>
                </tbody>
            </table>

            <?php if ($view->totalPages > 1) { ?>
                <nav class="om-worklist-pagination" aria-label="<?php echo e(I18N::translate('Pagination')); ?>">
                    <ul class="pagination">
                        <li class="page-item<?php echo $view->page <= 1 ? ' disabled' : ''; ?>">
                            <?php if ($view->page > 1) { ?>
                                <a class="page-link"
                                   href="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, [...$navParams, 'page' => $view->page - 1])); ?>"><?php echo e(I18N::translate('previous')); ?></a>
                            <?php } else { ?>
                                <span class="page-link"><?php echo e(I18N::translate('previous')); ?></span>
                            <?php } ?>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link"><?php echo e(I18N::translate('Page %1$s of %2$s', I18N::number($view->page), I18N::number($view->totalPages))); ?></span>
                        </li>
                        <li class="page-item<?php echo $view->page >= $view->totalPages ? ' disabled' : ''; ?>">
                            <?php if ($view->page < $view->totalPages) { ?>
                                <a class="page-link"
                                   href="<?php echo e(route(ObituaryWorklistHandler::ROUTE_NAME, [...$navParams, 'page' => $view->page + 1])); ?>"><?php echo e(I18N::translate('next')); ?></a>
                            <?php } else { ?>
                                <span class="page-link"><?php echo e(I18N::translate('next')); ?></span>
                            <?php } ?>
                        </li>
                    </ul>
                </nav>
            <?php } ?>
        <?php } ?>
    <?php } ?>
</div>
