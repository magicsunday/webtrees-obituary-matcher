{
    "name": "magicsunday/webtrees-obituary-matcher",
    "description": "Explainable entity-matching engine that scores webtrees individuals against public obituary notices to suggest missing death dates.",
    "license": "GPL-3.0-or-later",
    "type": "webtrees-module",
    "keywords": [
        "death-date",
        "entity-matching",
        "genealogy",
        "matcher",
        "obituary",
        "php",
        "scoring",
        "search",
        "webtrees"
    ],
    "authors": [
        {
            "name": "Rico Sonntag",
            "email": "mail@ricosonntag.de",
            "homepage": "https://ricosonntag.de",
            "role": "Developer"
        }
    ],
    "config": {
        "bin-dir": ".build/bin",
        "vendor-dir": ".build/vendor",
        "sort-packages": true,
        "optimize-autoloader": true,
        "policy": {
            "advisories": {
                "ignore": {
                    "guzzlehttp/guzzle": "Transitive dev/test dependency pinned exactly by fisharebest/webtrees; the module ships no guzzle and the admin's webtrees install governs the upgrade. New guzzle CVEs still surface via composer audit, and advisories on any other package still block resolution."
                }
            }
        }
    },
    "require": {
        "php": "8.3 - 8.5",
        "ext-calendar": "*",
        "ext-dom": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "fisharebest/webtrees": "~2.2.0 || dev-main",
        "magicsunday/webtrees-module-base": "^2.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.50",
        "opis/json-schema": "^2.6",
        "overtrue/phplint": "^9.0",
        "phpat/phpat": "^0.12.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0 || ^13.0",
        "rector/rector": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "MagicSunday\\ObituaryMatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MagicSunday\\ObituaryMatcher\\Test\\": "tests/"
        }
    },
    "scripts": {
        "ci:cgl": [
            "php-cs-fixer fix --config .php-cs-fixer.dist.php --diff --verbose"
        ],
        "ci:rector": [
            "rector process --config rector.php"
        ],
        "ci:test:php:cgl": [
            "@ci:cgl --dry-run"
        ],
        "ci:test:php:lint": [
            "phplint --configuration .phplint.yml"
        ],
        "ci:test:php:phpstan": [
            "phpstan analyse --configuration phpstan.neon --memory-limit=-1"
        ],
        "ci:test:php:phpstan-glue": [
            "phpstan analyse --configuration phpstan-glue.neon --memory-limit=-1"
        ],
        "ci:test:php:rector": [
            "@ci:rector --dry-run"
        ],
        "ci:test:php:unit": [
            "phpunit --configuration phpunit.xml --testsuite unit --display-all-issues"
        ],
        "ci:test:php:integration": [
            "phpunit --configuration phpunit.xml --testsuite integration --display-all-issues"
        ],
        "ci:test:php:interop": [
            "phpunit --configuration phpunit.xml --testsuite interop --display-all-issues"
        ],
        "ci:test:cpd": [
            "npx jscpd@5.0.11 src tests --config .jscpd.json --skip-comments --no-tips"
        ],
        "ci:test": [
            "@ci:test:php:lint",
            "@ci:test:php:cgl",
            "@ci:test:php:phpstan",
            "@ci:test:php:phpstan-glue",
            "@ci:test:php:rector",
            "@ci:test:cpd",
            "@ci:test:php:unit",
            "@ci:test:php:integration"
        ]
    }
}
