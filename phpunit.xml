<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="./.build/vendor/phpunit/phpunit/phpunit.xsd"
         beStrictAboutCoverageMetadata="true"
         beStrictAboutOutputDuringTests="true"
         bootstrap="./.build/vendor/autoload.php"
         cacheDirectory="./.build/cache/.phpunit.cache"
         colors="true"
         displayDetailsOnPhpunitDeprecations="true"
         executionOrder="depends,defects"
         failOnDeprecation="true"
         failOnNotice="true"
         failOnPhpunitDeprecation="true"
         failOnRisky="true"
         failOnWarning="true"
>
    <testsuites>
        <testsuite name="unit">
            <directory>tests/Contract</directory>
            <directory>tests/Domain</directory>
            <directory>tests/Matching</directory>
            <directory>tests/Parsing</directory>
            <directory>tests/Queue</directory>
            <directory>tests/Scoring</directory>
            <directory>tests/Support</directory>
            <directory>tests/Ui</directory>
            <directory>tests/Webtrees</directory>
        </testsuite>
        <testsuite name="integration">
            <directory>tests/Integration</directory>
        </testsuite>
        <!--
            The interop suite is DELIBERATELY separate: it is NOT part of `composer ci:test` and NOT wired
            into required CI (it drives a real, availability-gated finder over HTTP). Run it explicitly
            with `composer ci:test:php:interop`. See the README (Development section).
        -->
        <testsuite name="interop">
            <directory>tests/Interop</directory>
        </testsuite>
    </testsuites>

    <source ignoreIndirectDeprecations="true" restrictNotices="true" restrictWarnings="true">
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
